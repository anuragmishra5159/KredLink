# KredLink Express Backend — Environment Configuration
# Copy this file to .env or configure these variables in Render environment settings

# Port to bind the Express server (Render assigns this dynamically in production via $PORT)
PORT=5000

# MongoDB Connection URI (e.g. Local MongoDB or MongoDB Atlas URI)
MONGO_URI=mongodb://localhost:27017/kredlink

# JWT Authentication Config
JWT_SECRET=kredlink_hackathon_secret_2026
JWT_EXPIRES_IN=7d

# Python Scoring Microservice URL
# Local development defaults to http://localhost:5001
# In Render production, set this to the deployed Render service URL of the scoring app (e.g., https://kredlink-scoring.onrender.com)
SCORING_SERVICE_URL=http://localhost:5001

# CORS Allowed Origins (comma-separated, without trailing slashes)
# In Render production, add the URL of the deployed Vercel frontend (e.g. https://kredlink.vercel.app)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Node Environment
NODE_ENV=development
